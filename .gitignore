# Ignore everything in the root directory
/*

# EXCEPT the allowed folders and files
!/.claude-plugin/
!/plugins/
!/.github/
!/.gitignore
!/LICENSE.md
!/README.md
!/CONTRIBUTING.md
!/AGENTS.md
!/INSTALLATION.md

# (Optional) You can still apply rules to the contents of those allowed folders
# For example, to ignore system files inside /plugins/
# Apple system files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows system files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux system files
.directory
*~

# Editors and backup files
*.swp
*.swo
*.bak
*.tmp
*.temp
.gemini/
